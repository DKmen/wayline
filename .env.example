# Copy to .env.local (gitignored) and adjust per app. Same variable names in every
# environment (docs/08-local-dev.md §4) — only the values differ between local and AWS.

# Postgres (docker-compose `db` service)
DATABASE_URL=postgres://wayline:wayline@localhost:5432/wayline

# SQS stand-in (docker-compose `sqs` service — ElasticMQ)
SQS_ENDPOINT=http://localhost:9324

# S3 stand-in (docker-compose `s3` service — MinIO)
S3_ENDPOINT=http://localhost:9000

# Mailer: smtp (Mailpit, local) | ses (AWS, deployed environments)
MAILER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025

# Asset URL delivery: presign (local, direct MinIO presigned URLs) | cloudfront (deployed environments)
ASSET_URL_MODE=presign

# apps/api — Better Auth
APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=dev-only-change-me-32-chars-min

# Mailer sender identity (used by both smtp and ses mailer modes)
SMTP_FROM="Wayline <no-reply@wayline.app>"

# apps/api server port
PORT=3000
