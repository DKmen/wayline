{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/scripts/context-sync/context-sync.cli.mjs\" --for codex --hook",
            "timeout": 10,
            "statusMessage": "Loading Claude context"
          }
        ]
      }
    ]
  }
}
